  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "rebuild": "yarn clean && yarn build",
    "start": "node dist/server.mjs",
    "dev": "tsx watch src/server.ts",
    "format": "prettier --config ./prettier.config.js . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pm2:dev": "pm2 start ecosystem.config.cjs --only keepwatching-admin-server-dev",
    "pm2:prod": "npm run build && pm2 start ecosystem.config.cjs --env production --only keepwatching-admin-server",
    "pm2:stop:dev": "pm2 stop keepwatching-admin-server-dev",
    "pm2:stop:prod": "pm2 stop keepwatching-admin-server",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "start:dev": "./scripts/start-admin.sh dev",
    "start:prod": "./scripts/start-admin.sh prod",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
